APP_NAME="CRM Advogado"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://app.advogadointernacional.net

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# Fuso horário: decisão pendente (ver CLAUDE.md secção "Decisões pendentes").
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Conexão MySQL do CRM (banco "crm_advogado") — configuração de PRODUÇÃO/VPS Hostinger.
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=crm_advogado
# DB_USERNAME=root
# DB_PASSWORD=

# Configuração para desenvolvimento local sem MySQL instalado.
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# E-mail (Bloco 6): em produção, trocar MAIL_MAILER para "smtp" e preencher credenciais
# reais — ver CLAUDE.md, seção "E-mail automático (Bloco 6)".
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google Calendar (Bloco 7) — ver CLAUDE.md para o roteiro de criação das credenciais.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:8000/admin/configuracoes/agenda/callback

# Relatórios automáticos (Bloco 8).
ADMIN_REPORT_EMAIL=
ADMIN_REPORT_SEND_TIME=07:00

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
